# Sensitive / large binaries
*.vsix
*.pdf
*.docx

# Claude Code local state
.claude/

# Editor / OS
.DS_Store
Thumbs.db
.vscode/settings.json

# Local env / state — defence-in-depth on top of per-folder .gitignores
**/.env
**/.env.local
**/.env.*.local
**/terraform.tfvars
**/*.tfstate
**/*.tfstate.*
**/.terraform/
**/.terraform.lock.hcl.bak
**/node_modules/

# NEVER COMMIT cryptographic key material — Secrets Manager / Vault only
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/secrets/
!**/secrets/**/*.tf
!**/secrets/**/*.md

# Block accidental zip-into-self folder copies
vidyouth-v2-master/
vidyouth-v2-main/

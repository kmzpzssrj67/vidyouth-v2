{
  "name": "vidyouth-login-api",
  "version": "0.1.0",
  "private": true,
  "description": "Vidyouth LMS authentication service",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "echo 'add eslint when ready'",
    "test": "node --import tsx --import ./tests/setup.ts --test --test-reporter=spec \"tests/**/*.test.ts\"",
    "test:unit": "node --import tsx --import ./tests/setup.ts --test --test-reporter=spec \"tests/unit/**/*.test.ts\"",
    "test:integration": "node --import tsx --import ./tests/setup.ts --test --test-reporter=spec \"tests/integration/**/*.test.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.654.0",
    "@aws-sdk/client-sns": "^3.654.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "ioredis": "^5.4.1",
    "jose": "^5.4.0",
    "pg": "^8.11.5",
    "pino-pretty": "^11.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "tsx": "^4.11.2",
    "typescript": "^5.4.5"
  }
}

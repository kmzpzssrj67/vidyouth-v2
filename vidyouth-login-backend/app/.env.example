# Vidyouth login API — environment template.
# Copy to .env (gitignored) for local dev. In AWS we read these from
# Secrets Manager + SSM at boot via the EC2 IAM role.

NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Postgres
DATABASE_URL=postgres://vidyouth:devpass@localhost:5432/vidyouth_lms
PG_POOL_MAX=10
PG_POOL_IDLE_MS=10000

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=vidyouth:dev:

# JWT (RS256). Paste full PEM strings, including the BEGIN/END lines.
# Keep newlines as \n inside the .env value (dotenv parses them).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=vidyouth.auth
JWT_AUDIENCE=vidyouth.lms
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Password hardening
BCRYPT_ROUNDS=12
BCRYPT_PEPPER=replace-with-32-random-bytes

# Lockout policy (matches Redis TTLs in src/services/lockout.ts)
LOCKOUT_MAX_FAILED=5
LOCKOUT_WINDOW_SECONDS=1800
LOCKOUT_DURATION_SECONDS=1800

# Sessions
SESSION_MAX_PER_USER=3

# OTP
OTP_TTL_SECONDS=600
OTP_LENGTH=6
OTP_RATE_LIMIT_WINDOW_SECONDS=600
OTP_RATE_LIMIT_MAX=5

# SMS provider: sns for AWS SMS delivery, msg91 for MSG91 delivery.
# Use mock only in automated tests.
SMS_PROVIDER=sns
SMS_API_KEY=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

# Email provider: ses for AWS SES delivery.
# Use mock only in automated tests.
EMAIL_PROVIDER=ses
EMAIL_FROM=vidyouth2@gmail.com

# Audit
AUDIT_S3_BUCKET=
AUDIT_S3_REGION=ap-south-1

# Google OAuth
GOOGLE_CLIENT_ID= 
GOOGLE_CLIENT_SECRET= 
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID= 
MICROSOFT_CLIENT_SECRET= 
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8080/auth/microsoft/callback

# Frontend URL used in email verification and password reset links.
APP_BASE_URL=http://localhost:3000

# AWS SES/SNS delivery. Keep real values only in .env, never in Git.
AWS_REGION=ap-south-1
AWS_SMS_REGION=us-east-1
AWS_EMAIL_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
SES_FROM_EMAIL=vidyouth2@gmail.com
SNS_SMS_TYPE=Transactional
SNS_SENDER_ID=
SNS_ENTITY_ID=
SNS_TEMPLATE_ID=

# Copy this file to .env in the vidyouth-login-backend folder.
# Docker Compose reads .env automatically for ${VARIABLE} values.
# Never commit real AWS keys, JWT keys, or passwords.

API_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

POSTGRES_DB=vidyouth_lms
POSTGRES_USER=vidyouth
POSTGRES_PASSWORD=devpass

LOG_LEVEL=debug
PG_POOL_MAX=10
PG_POOL_IDLE_MS=10000
REDIS_KEY_PREFIX=vidyouth:dev:

BCRYPT_ROUNDS=12
BCRYPT_PEPPER=replace-with-32-random-bytes-minimum

# Required for auth routes that issue JWTs.
# For local Docker, scripts/run-local.ps1 exports these from ./secrets.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=vidyouth.auth
JWT_AUDIENCE=vidyouth.lms
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

LOCKOUT_MAX_FAILED=5
LOCKOUT_WINDOW_SECONDS=1800
LOCKOUT_DURATION_SECONDS=1800
SESSION_MAX_PER_USER=3

OTP_TTL_SECONDS=600
OTP_LENGTH=6
OTP_RATE_LIMIT_WINDOW_SECONDS=600
OTP_RATE_LIMIT_MAX=5

# Real delivery providers. Use mock only for automated tests.
SMS_PROVIDER=sns
EMAIL_PROVIDER=ses

# AWS SES email delivery.
EMAIL_FROM=vidyouth2@gmail.com
SES_FROM_EMAIL=vidyouth2@gmail.com
AWS_REGION=ap-south-1
AWS_SMS_REGION=us-east-1
AWS_EMAIL_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# AWS SNS SMS delivery. India local-route SMS can need approved DLT values.
SNS_SMS_TYPE=Transactional
SNS_SENDER_ID=
SNS_ENTITY_ID=
SNS_TEMPLATE_ID=

# Optional MSG91 alternative for SMS instead of SNS.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600
APP_BASE_URL=http://localhost:3000

AUDIT_S3_BUCKET=
AUDIT_S3_REGION=ap-south-1

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8080/auth/microsoft/callback

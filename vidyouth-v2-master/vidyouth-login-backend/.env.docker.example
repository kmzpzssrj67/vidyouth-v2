# Copy this file to .env in the vidyouth-login-backend folder.
# Docker Compose reads .env automatically for ${VARIABLE} values.

API_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

POSTGRES_DB=vidyouth_lms
POSTGRES_USER=vidyouth
POSTGRES_PASSWORD=devpass

LOG_LEVEL=debug
PG_POOL_MAX=10
PG_POOL_IDLE_MS=10000
REDIS_KEY_PREFIX=vidyouth:dev:

BCRYPT_ROUNDS=12
BCRYPT_PEPPER=2955424611aee6b77723433184a63f18efdf269b8c63c00820e5ea1b5e472a58


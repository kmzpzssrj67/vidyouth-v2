# Vidyouth login API — environment template.
# Copy to .env (gitignored) for local dev. In AWS we read these from
# Secrets Manager + SSM at boot via the EC2 IAM role.

NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Postgres
DATABASE_URL=postgres://vidyouth:devpass@localhost:5432/vidyouth_lms
PG_POOL_MAX=10
PG_POOL_IDLE_MS=10000

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=vidyouth:dev:

# JWT (RS256). Paste full PEM strings, including the BEGIN/END lines.
# Keep newlines as \n inside the .env value (dotenv parses them).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=vidyouth.auth
JWT_AUDIENCE=vidyouth.lms
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Password hardening
BCRYPT_ROUNDS=12
BCRYPT_PEPPER=replace-with-32-random-bytes

# Lockout policy (matches Redis TTLs in src/services/lockout.ts)
LOCKOUT_MAX_FAILED=5
LOCKOUT_WINDOW_SECONDS=1800
LOCKOUT_DURATION_SECONDS=1800

# Sessions
SESSION_MAX_PER_USER=3

# OTP
OTP_TTL_SECONDS=600
OTP_LENGTH=6
OTP_RATE_LIMIT_WINDOW_SECONDS=600
OTP_RATE_LIMIT_MAX=5

# SMS provider (mock local, SNS for real OTP delivery)
SMS_PROVIDER=mock
SMS_API_KEY=
SNS_SENDER_ID=
SNS_SMS_TYPE=Transactional

# Email provider (SES later; mock for local)
EMAIL_PROVIDER=mock
EMAIL_FROM=no-reply@vidyouth.local
SES_FROM_EMAIL=no-reply@vidyouth.local
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600
APP_BASE_URL=http://localhost:3000

# AWS provider credentials for local Docker when EMAIL_PROVIDER=ses or SMS_PROVIDER=sns.
# Prefer a restricted IAM user for development.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Audit
AUDIT_S3_BUCKET=
AUDIT_S3_REGION=ap-south-1
